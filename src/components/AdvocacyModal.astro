<div
    id="advocacyModal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4"
>
    <div
        class="bg-white w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-xl shadow-2xl"
    >
        <div class="flex items-center justify-between border-b p-6">
            <h2 class="text-2xl font-bold text-orange-700">
                🌍 Join the Movement
            </h2>

            <button
                id="closeAdvocacyModal"
                class="text-3xl hover:text-red-500 transition"
            >
                &times;
            </button>
        </div>

        <div class="p-6 space-y-8 text-slate-700 leading-7">
            <section>
                <h3 class="text-xl font-semibold text-orange-700 mb-3">
                    Why We Created This Advocacy
                </h3>

                <p>
                    Air pollution affects millions of people every day. It
                    contributes to respiratory diseases, climate change, and
                    environmental degradation. This digital advocacy page was
                    created to educate people, raise awareness, and encourage
                    everyone to become part of the solution.
                </p>

                <p class="mt-3">
                    Our advocacy stands for cleaner air, healthier communities,
                    and responsible environmental stewardship. We believe that
                    small actions, when multiplied by many people, can create
                    meaningful change.
                </p>
            </section>

            <section>
                <h3 class="text-xl font-semibold text-orange-700 mb-3">
                    Key Insights
                </h3>

                <p>
                    Based on the information presented throughout this advocacy,
                    air pollution is caused largely by vehicle emissions,
                    industrial activities, open burning, and poor waste
                    management. These pollutants threaten both human health and
                    the Earth's ecosystems.
                </p>

                <p class="mt-3">
                    Protecting our environment requires collective action from
                    individuals, communities, businesses, and government
                    agencies. Awareness alone is not enough—we must act.
                </p>
            </section>

            <section>
                <h3 class="text-xl font-semibold text-orange-700 mb-3">
                    How You Can Help
                </h3>

                <ul class="list-disc ml-6 space-y-2">
                    <li>
                        Use public transportation, bike, or walk whenever
                        possible.
                    </li>
                    <li>Avoid burning trash and properly segregate waste.</li>
                    <li>Plant and protect trees to improve air quality.</li>
                    <li>
                        Conserve electricity and reduce unnecessary energy
                        consumption.
                    </li>
                    <li>
                        Support clean energy and environmentally responsible
                        businesses.
                    </li>
                    <li>
                        Share verified environmental information to educate
                        others.
                    </li>
                    <li>
                        Participate in local clean-up drives and environmental
                        programs.
                    </li>
                </ul>
            </section>

            <section>
                <h3 class="text-xl font-semibold text-orange-700 mb-3">
                    Be Part of the Change
                </h3>

                <p>
                    Every action matters. Whether it's reducing emissions,
                    conserving energy, planting trees, or educating others, your
                    efforts contribute to a healthier planet. Together, we can
                    protect the Earth's ecosystem for future generations.
                </p>
            </section>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById("advocacyModal");
    const closeBtn = document.getElementById("closeAdvocacyModal");

    // Every button with this class will open the modal
    const openButtons = document.querySelectorAll(".openAdvocacyModal");

    function openModal() {
        modal?.classList.remove("hidden");
        modal?.classList.add("flex");
        document.body.style.overflow = "hidden";
    }

    function closeModal() {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
        document.body.style.overflow = "";
    }

    openButtons.forEach((button) => {
        button.addEventListener("click", openModal);
    });

    closeBtn?.addEventListener("click", closeModal);

    modal?.addEventListener("click", (e) => {
        if (e.target === modal) {
            closeModal();
        }
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
            closeModal();
        }
    });
</script>
