<div
    id="disclaimer-notification"
    class="fixed right-4 bottom-4 z-[100] w-[calc(100%-2rem)] max-w-sm translate-y-4 rounded-lg border border-slate-200 bg-white p-4 opacity-0 shadow-xl transition duration-300 ease-out sm:right-6 sm:bottom-6"
    role="status"
    aria-labelledby="disclaimer-title"
>
    <h2 id="disclaimer-title" class="text-sm font-bold text-slate-950">
        Academic Project Disclaimer
    </h2>
    <p class="mt-2 text-xs leading-5 text-slate-700">
        This website is an MMDC student project for educational purposes only
        and does not represent any organization or institution.
    </p>
    <p class="mt-2 text-xs leading-5 text-slate-500">
        Built with JavaScript, TypeScript, Astro, and Tailwind CSS.
    </p>
    <div class="mt-3">
        <p class="text-xs font-medium text-slate-500">
            Closing in <span data-countdown>10</span>s
        </p>
        <div class="mt-2 h-1 overflow-hidden rounded-full bg-slate-200">
            <div
                class="h-full w-full origin-left rounded-full bg-orange-700"
                data-countdown-progress
            >
            </div>
        </div>
    </div>
</div>

<script>
    const notification = document.querySelector("#disclaimer-notification");
    const countdown = document.querySelector("[data-countdown]");
    const progress = document.querySelector("[data-countdown-progress]");
    const duration = 10;
    let secondsLeft = duration;

    requestAnimationFrame(() => {
        notification?.classList.remove("translate-y-4", "opacity-0");
        notification?.classList.add("translate-y-0", "opacity-100");
        progress?.animate(
            [{ transform: "scaleX(1)" }, { transform: "scaleX(0)" }],
            {
                duration: duration * 1000,
                easing: "linear",
                fill: "forwards",
            },
        );
    });

    const countdownTimer = window.setInterval(() => {
        secondsLeft -= 1;

        if (countdown) {
            countdown.textContent = String(secondsLeft);
        }

        if (secondsLeft <= 0) {
            window.clearInterval(countdownTimer);
        }
    }, 1000);

    window.setTimeout(() => {
        window.clearInterval(countdownTimer);
        notification?.classList.add("translate-y-4", "opacity-0");
        notification?.classList.remove("translate-y-0", "opacity-100");
    }, duration * 1000);

    window.setTimeout(
        () => {
            notification?.remove();
        },
        duration * 1000 + 400,
    );
</script>
